# AICmd model setup / AICmd 模型设置
#
# English:
# 1. Copy this file to .env before installation.
# 2. Configure exactly one provider: openai, anthropic, or google.
# 3. Fill only the values below.
# 4. Run: contrib/aicmd/install.sh
#
# 中文：
# 1. 安装前复制本文件为 .env。
# 2. 只配置一种模型接口：openai、anthropic 或 google。
# 3. 只填写下面几个值。
# 4. 运行：contrib/aicmd/install.sh

# Model display name. This is the single client name used by AICmd.
# 模型名称 / 唯一客户端标识，例如：openai、claude、gemini、deepseek
AICMD_MODEL_NAME=openai

# Provider kind: openai | anthropic | google
# 模型接口种类：openai | anthropic | google
AICMD_MODEL_PROVIDER=openai

# API base URL.
# 模型 API 地址。
AICMD_MODEL_API_BASE=https://api.openai.com/v1

# API key.
# 模型 API Key。
AICMD_MODEL_API_KEY=sk-xxxx

# Real model ids sent to the provider. Use comma-separated ids for multiple models.
# 发送给模型服务商的模型 ID。多个模型用英文逗号分隔。
AICMD_MODEL_IDS=gpt-4o,gpt-4.1

# Optional default model written to config.yaml `model:`.
# If omitted, AICmd uses: AICMD_MODEL_NAME:first id in AICMD_MODEL_IDS
# 可选：写入 config.yaml 顶部 `model:` 的默认模型。
# 不填时默认使用：AICMD_MODEL_NAME:AICMD_MODEL_IDS 里的第一个模型 ID
# AICMD_DEFAULT_MODEL=openai:gpt-4o

# OpenAI only: chat | responses
# 仅 openai 需要：chat | responses
AICMD_OPENAI_API_STYLE=chat


# MCP search setup / MCP 搜索配置
# `aicmd-model init --from-env` writes these values to ~/.aicmd/config.json.
# Runtime search commands read ~/.aicmd/config.json directly, not .env.
# `aicmd-model init --from-env` 会把这些值写入 ~/.aicmd/config.json。
# 运行时搜索命令直接读取 ~/.aicmd/config.json，不读取 .env。
AICMD_MCP_TAVILY_API_KEY=tvly-xxxx
# Optional: use a Tavily key file instead of a single key / 可选：使用 Tavily key 文件而不是单个 key
# AICMD_MCP_TAVILY_API_KEYS_FILE="$HOME/.aicmd/tavily-keys.txt"

# To switch provider or MCP settings later, edit this same .env file and regenerate config.yaml/config.json:
#   aicmd-model init --from-env --force
#
# 后续如需切换模型服务商或 MCP 设置，修改同一个 .env 文件后重新生成 config.yaml/config.json：
#   aicmd-model init --from-env --force
#
# Examples / 示例：
#
# Anthropic:
# AICMD_MODEL_NAME=claude
# AICMD_MODEL_PROVIDER=anthropic
# AICMD_MODEL_API_BASE=https://api.anthropic.com/v1
# AICMD_MODEL_API_KEY=sk-ant-xxxx
# AICMD_MODEL_IDS=claude-3-5-sonnet-latest
#
# Google Gemini:
# AICMD_MODEL_NAME=gemini
# AICMD_MODEL_PROVIDER=google
# AICMD_MODEL_API_BASE=https://generativelanguage.googleapis.com/v1beta
# AICMD_MODEL_API_KEY=xxxx
# AICMD_MODEL_IDS=gemini-2.5-flash
#
# OpenAI Responses API:
# AICMD_MODEL_NAME=openai
# AICMD_MODEL_PROVIDER=openai
# AICMD_MODEL_API_BASE=https://api.openai.com/v1
# AICMD_MODEL_API_KEY=sk-xxxx
# AICMD_MODEL_IDS=gpt-4.1
# AICMD_OPENAI_API_STYLE=responses
