# AICmd model setup / AICmd 模型设置
#
# English:
# 1. Copy this file to .env before installation.
# 2. Choose one provider: openai, anthropic, or google.
# 3. Fill only the values below.
# 4. Run: contrib/aicmd/install.sh
#
# 中文：
# 1. 安装前复制本文件为 .env。
# 2. 选择一种模型接口：openai、anthropic 或 google。
# 3. 只填写下面几个值。
# 4. 运行：contrib/aicmd/install.sh

# Model display name. This is the client name used by AICmd.
# 模型名称 / 客户端标识，例如：openai、claude、gemini、deepseek
AICMD_MODEL_NAME=openai

# Provider kind: openai | anthropic | google
# 模型接口种类：openai | anthropic | google
AICMD_MODEL_PROVIDER=openai

# API base URL.
# 模型 API 地址。
AICMD_MODEL_API_BASE=https://api.openai.com/v1

# API key.
# 模型 API Key。
AICMD_MODEL_API_KEY=sk-xxxx

# Real model id sent to the provider.
# 发送给模型服务商的模型 ID。
AICMD_MODEL_ID=gpt-4o

# Optional default model written to config.yaml `model:`.
# If omitted, AICmd uses: AICMD_MODEL_NAME:AICMD_MODEL_ID
# 可选：写入 config.yaml 顶部 `model:` 的默认模型。
# 不填时默认使用：AICMD_MODEL_NAME:AICMD_MODEL_ID
# AICMD_DEFAULT_MODEL=openai:gpt-4o

# OpenAI only: chat | responses
# 仅 openai 需要：chat | responses
AICMD_OPENAI_API_STYLE=chat

# Examples / 示例：
#
# Anthropic:
# AICMD_MODEL_NAME=claude
# AICMD_MODEL_PROVIDER=anthropic
# AICMD_MODEL_API_BASE=https://api.anthropic.com/v1
# AICMD_MODEL_API_KEY=sk-ant-xxxx
# AICMD_MODEL_ID=claude-3-5-sonnet-latest
#
# Google Gemini:
# AICMD_MODEL_NAME=gemini
# AICMD_MODEL_PROVIDER=google
# AICMD_MODEL_API_BASE=https://generativelanguage.googleapis.com/v1beta
# AICMD_MODEL_API_KEY=xxxx
# AICMD_MODEL_ID=gemini-2.5-flash
#
# OpenAI Responses API:
# AICMD_MODEL_NAME=openai
# AICMD_MODEL_PROVIDER=openai
# AICMD_MODEL_API_BASE=https://api.openai.com/v1
# AICMD_MODEL_API_KEY=sk-xxxx
# AICMD_MODEL_ID=gpt-4.1
# AICMD_OPENAI_API_STYLE=responses
