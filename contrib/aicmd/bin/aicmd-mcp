#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'HELP'
Usage: aicmd-mcp <command> [args...]

Call MCP-backed tools through dedicated AICmd helper commands.
MCP runtime settings are read from ~/.aicmd/config.yaml using standard MCP server config shape.

用法：aicmd-mcp <命令> [参数...]

通过独立 AICmd 辅助命令调用 MCP 工具。
MCP 运行时配置从 ~/.aicmd/config.yaml 读取，配置结构使用标准 MCP server 形态。

Commands / 命令:
  search <query>   Search the web using configured Tavily MCP / 使用配置的 Tavily MCP 搜索网页
  tavily <query>   Alias of search / search 的别名
  help             Show help / 显示帮助

Examples / 示例:
  aicmd-mcp search "今天 AI 新闻"
  aicmd-mcp tavily "DeepSeek latest model"
HELP
}

config_dir() {
  if [[ -n "${AICMD_CONFIG_DIR:-}" ]]; then
    printf '%s\n' "$AICMD_CONFIG_DIR"
  else
    printf '%s/.aicmd\n' "$HOME"
  fi
}

config_path() {
  if [[ -n "${AICMD_CONFIG_FILE:-}" ]]; then
    printf '%s\n' "$AICMD_CONFIG_FILE"
  else
    printf '%s/config.yaml\n' "$(config_dir)"
  fi
}

run_tavily() {
  local query path
  query="$*"
  if [[ -z "$query" ]]; then
    echo "usage: aicmd-mcp search <query>" >&2
    exit 2
  fi
  path="$(config_path)"
  if [[ ! -f "$path" ]]; then
    echo "config not found: $path" >&2
    echo "Run: aicmd init --from-env" >&2
    exit 1
  fi
  python3 - "$path" "$query" <<'PY'
import json
import os
import subprocess
import sys
import threading
import time

import yaml

config_path, query = sys.argv[1], sys.argv[2]
with open(config_path, "r", encoding="utf-8") as f:
    config = yaml.safe_load(f) or {}
server = config.get("mcpServers", {}).get("tavily")
if not server:
    raise SystemExit(f"missing mcpServers.tavily in {config_path}")
if server.get("type", "stdio") != "stdio":
    raise SystemExit("mcpServers.tavily.type must be stdio")
command = server.get("command")
args = server.get("args", [])
if not command:
    raise SystemExit(f"missing mcpServers.tavily.command in {config_path}")
if not isinstance(args, list):
    raise SystemExit("mcpServers.tavily.args must be an array")
server_env = server.get("env", {}) or {}
if not isinstance(server_env, dict):
    raise SystemExit("mcpServers.tavily.env must be an object")

env = os.environ.copy()
for key, value in server_env.items():
    if value is not None and str(value) != "":
        env[str(key)] = str(value)

proc = subprocess.Popen(
    [str(command), *map(str, args)],
    stdin=subprocess.PIPE,
    stdout=subprocess.PIPE,
    stderr=subprocess.PIPE,
    text=True,
    bufsize=1,
    env=env,
)

stderr_lines = []
def read_stderr():
    assert proc.stderr is not None
    for line in proc.stderr:
        stderr_lines.append(line)
threading.Thread(target=read_stderr, daemon=True).start()

next_id = 1

def send(method, params=None, is_notification=False):
    global next_id
    msg = {"jsonrpc": "2.0", "method": method}
    if params is not None:
        msg["params"] = params
    if not is_notification:
        msg["id"] = next_id
        next_id += 1
    assert proc.stdin is not None
    proc.stdin.write(json.dumps(msg, separators=(",", ":")) + "\n")
    proc.stdin.flush()
    return msg.get("id")

def read_response(expected_id, timeout=60):
    assert proc.stdout is not None
    deadline = time.time() + timeout
    while time.time() < deadline:
        line = proc.stdout.readline()
        if not line:
            if proc.poll() is not None:
                err = "".join(stderr_lines).strip()
                raise SystemExit(err or f"MCP server exited with code {proc.returncode}")
            continue
        line = line.strip()
        if not line:
            continue
        try:
            msg = json.loads(line)
        except json.JSONDecodeError:
            continue
        if msg.get("id") == expected_id:
            if "error" in msg:
                raise SystemExit(json.dumps(msg["error"], ensure_ascii=False))
            return msg.get("result", {})
    raise SystemExit("timed out waiting for MCP response")

init_id = send("initialize", {
    "protocolVersion": "2024-11-05",
    "capabilities": {},
    "clientInfo": {"name": "aicmd-mcp", "version": "0.1.0"},
})
read_response(init_id)
send("notifications/initialized", {}, is_notification=True)

call_id = send("tools/call", {
    "name": "tavily_search",
    "arguments": {
        "query": query,
        "topic": "general",
        "search_depth": "advanced",
        "max_results": 5,
        "include_answer": True,
        "include_raw_content": False,
        "include_images": False,
        "include_image_descriptions": False,
    },
})
result = read_response(call_id, timeout=120)
content = result.get("content", [])
texts = []
for item in content:
    if isinstance(item, dict) and isinstance(item.get("text"), str):
        texts.append(item["text"])
print("\n".join(texts), end="")

try:
    proc.terminate()
except Exception:
    pass
PY
}

cmd="${1:-help}"
case "$cmd" in
  search|tavily)
    shift || true
    run_tavily "$@" ;;
  help|-h|--help)
    usage ;;
  *)
    echo "Unknown command: $cmd" >&2
    usage >&2
    exit 2 ;;
esac
