#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'HELP'
Usage: aicmd-mcp <command> [args...]

Call MCP-backed commands configured in ~/.aicmd/mcp.json.

用法：aicmd-mcp <命令> [参数...]

调用 ~/.aicmd/mcp.json 中配置的 MCP 命令。

Commands / 命令:
  list             List configured MCP commands / 列出已配置的 MCP 命令
  <command> ...    Run a configured MCP command / 运行已配置的 MCP 命令
  help             Show help / 显示帮助

Examples / 示例:
  aicmd-mcp search "今天 AI 新闻"
  aicmd-mcp context7-library react
HELP
}

config_dir() {
  if [[ -n "${AICMD_CONFIG_DIR:-}" ]]; then
    printf '%s\n' "$AICMD_CONFIG_DIR"
  else
    printf '%s/.aicmd\n' "$HOME"
  fi
}

mcp_config_path() {
  if [[ -n "${AICMD_MCP_CONFIG_FILE:-}" ]]; then
    printf '%s\n' "$AICMD_MCP_CONFIG_FILE"
  else
    printf '%s/mcp.json\n' "$(config_dir)"
  fi
}

run_mcp_command() {
  local mcp_command input path
  mcp_command="$1"
  shift || true
  input="$*"
  path="$(mcp_config_path)"
  if [[ ! -f "$path" ]]; then
    echo "MCP config not found: $path" >&2
    echo "Create it before use, or install from the project mcp.json." >&2
    exit 1
  fi
  python3 - "$path" "$mcp_command" "$input" <<'PY'
import json
import os
import subprocess
import sys
import threading
import time
from copy import deepcopy

config_path, command_name, user_input = sys.argv[1], sys.argv[2], sys.argv[3]
with open(config_path, "r", encoding="utf-8") as f:
    config = json.load(f)
root = config.get("mcp", config)
servers = root.get("servers") or root.get("mcpServers") or {}
commands = root.get("commands") or {}

if command_name == "list":
    for name, spec in commands.items():
        desc = spec.get("description", "") if isinstance(spec, dict) else ""
        print(f"{name}\t{desc}".rstrip())
    raise SystemExit(0)

command_spec = commands.get(command_name)
if not command_spec:
    available = ", ".join(sorted(commands)) or "<none>"
    raise SystemExit(f"unknown MCP command: {command_name}\navailable: {available}")
server_name = command_spec.get("server")
tool_name = command_spec.get("tool")
if not server_name or not tool_name:
    raise SystemExit(f"MCP command {command_name!r} requires server and tool")
server = servers.get(server_name)
if not server:
    raise SystemExit(f"MCP server {server_name!r} not found for command {command_name!r}")
if server.get("type", "stdio") != "stdio":
    raise SystemExit(f"MCP server {server_name!r} type must be stdio")
server_command = server.get("command")
server_args = server.get("args", [])
if not server_command:
    raise SystemExit(f"MCP server {server_name!r} missing command")
if not isinstance(server_args, list):
    raise SystemExit(f"MCP server {server_name!r} args must be an array")
server_env = server.get("env", {}) or {}
if not isinstance(server_env, dict):
    raise SystemExit(f"MCP server {server_name!r} env must be an object")

def render(value):
    if isinstance(value, str):
        return value.replace("{{input}}", user_input)
    if isinstance(value, list):
        return [render(item) for item in value]
    if isinstance(value, dict):
        return {key: render(item) for key, item in value.items()}
    return value

tool_arguments = render(deepcopy(command_spec.get("arguments", {})))
if not isinstance(tool_arguments, dict):
    raise SystemExit(f"MCP command {command_name!r} arguments must be an object")

env = os.environ.copy()
for key, value in server_env.items():
    if value is not None and str(value) != "":
        env[str(key)] = str(value)

proc = subprocess.Popen(
    [str(server_command), *map(str, server_args)],
    stdin=subprocess.PIPE,
    stdout=subprocess.PIPE,
    stderr=subprocess.PIPE,
    text=True,
    bufsize=1,
    env=env,
)

stderr_lines = []
def read_stderr():
    assert proc.stderr is not None
    for line in proc.stderr:
        stderr_lines.append(line)
threading.Thread(target=read_stderr, daemon=True).start()

next_id = 1

def send(method, params=None, is_notification=False):
    global next_id
    msg = {"jsonrpc": "2.0", "method": method}
    if params is not None:
        msg["params"] = params
    if not is_notification:
        msg["id"] = next_id
        next_id += 1
    assert proc.stdin is not None
    proc.stdin.write(json.dumps(msg, separators=(",", ":")) + "\n")
    proc.stdin.flush()
    return msg.get("id")

def read_response(expected_id, timeout=60):
    assert proc.stdout is not None
    deadline = time.time() + timeout
    while time.time() < deadline:
        line = proc.stdout.readline()
        if not line:
            if proc.poll() is not None:
                err = "".join(stderr_lines).strip()
                raise SystemExit(err or f"MCP server exited with code {proc.returncode}")
            continue
        line = line.strip()
        if not line:
            continue
        try:
            msg = json.loads(line)
        except json.JSONDecodeError:
            continue
        if msg.get("id") == expected_id:
            if "error" in msg:
                raise SystemExit(json.dumps(msg["error"], ensure_ascii=False))
            return msg.get("result", {})
    raise SystemExit("timed out waiting for MCP response")

init_id = send("initialize", {
    "protocolVersion": "2024-11-05",
    "capabilities": {},
    "clientInfo": {"name": "aicmd-mcp", "version": "0.1.0"},
})
read_response(init_id)
send("notifications/initialized", {}, is_notification=True)

call_id = send("tools/call", {"name": tool_name, "arguments": tool_arguments})
result = read_response(call_id, timeout=120)
content = result.get("content", [])
texts = []
for item in content:
    if isinstance(item, dict) and isinstance(item.get("text"), str):
        texts.append(item["text"])
print("\n".join(texts), end="")

try:
    proc.terminate()
except Exception:
    pass
PY
}

cmd="${1:-help}"
case "$cmd" in
  help|-h|--help)
    usage ;;
  list)
    run_mcp_command list ;;
  *)
    shift || true
    run_mcp_command "$cmd" "$@" ;;
esac
