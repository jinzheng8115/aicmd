#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'HELP'
Usage: aicmd-mcp <command> [args...]

Call MCP-backed commands configured in ~/.aicmd/mcp.json.

用法：aicmd-mcp <命令> [参数...]

调用 ~/.aicmd/mcp.json 中配置的 MCP 命令。

Commands / 命令:
  list             List configured MCP commands / 列出已配置的 MCP 命令
  <command> ...    Run a configured MCP command / 运行已配置的 MCP 命令
  help             Show help / 显示帮助

Examples / 示例:
  aicmd-mcp search "今天 AI 新闻"
  aicmd-mcp context7-library react
HELP
}

config_dir() {
  if [[ -n "${AICMD_CONFIG_DIR:-}" ]]; then
    printf '%s\n' "$AICMD_CONFIG_DIR"
  else
    printf '%s/.aicmd\n' "$HOME"
  fi
}

mcp_config_path() {
  if [[ -n "${AICMD_MCP_CONFIG_FILE:-}" ]]; then
    printf '%s\n' "$AICMD_MCP_CONFIG_FILE"
  else
    printf '%s/mcp.json\n' "$(config_dir)"
  fi
}

run_mcp_command() {
  local mcp_command input path
  mcp_command="$1"
  shift || true
  input="$*"
  path="$(mcp_config_path)"
  if [[ ! -f "$path" ]]; then
    echo "MCP config not found: $path" >&2
    echo "Create it before use, or install from the project mcp.json." >&2
    exit 1
  fi
  python3 - "$path" "$mcp_command" "$input" <<'PY'
import json
import os
import subprocess
import sys
import threading
import time
config_path, command_name, user_input = sys.argv[1], sys.argv[2], sys.argv[3]
with open(config_path, "r", encoding="utf-8") as f:
    config = json.load(f)
root = config.get("mcp", config)
servers = root.get("servers") or root.get("mcpServers") or {}
commands = root.get("commands") or {}

if command_name == "list":
    for name, spec in commands.items():
        desc = spec.get("description", "") if isinstance(spec, dict) else ""
        print(f"{name}\t{desc}".rstrip())
    raise SystemExit(0)

command_spec = commands.get(command_name)
if not command_spec:
    available = ", ".join(sorted(commands)) or "<none>"
    raise SystemExit(f"unknown MCP command: {command_name}\navailable: {available}")
server_name = command_spec.get("server")
tool_name = command_spec.get("tool")
if not server_name:
    raise SystemExit(f"MCP command {command_name!r} requires server")
server = servers.get(server_name)
if not server:
    raise SystemExit(f"MCP server {server_name!r} not found for command {command_name!r}")
if server.get("type", "stdio") != "stdio":
    raise SystemExit(f"MCP server {server_name!r} type must be stdio")
server_command = server.get("command")
server_args = server.get("args", [])
if not server_command:
    raise SystemExit(f"MCP server {server_name!r} missing command")
if not isinstance(server_args, list):
    raise SystemExit(f"MCP server {server_name!r} args must be an array")
server_env = server.get("env", {}) or {}
if not isinstance(server_env, dict):
    raise SystemExit(f"MCP server {server_name!r} env must be an object")

def render(value):
    if isinstance(value, str):
        return value.replace("{{input}}", user_input)
    if isinstance(value, list):
        return [render(item) for item in value]
    if isinstance(value, dict):
        return {key: render(item) for key, item in value.items()}
    return value

def default_arguments(tool, text):
    if tool in ("tavily_search", "search"):
        return {
            "query": text,
            "topic": "general",
            "search_depth": "advanced",
            "max_results": 5,
            "include_answer": True,
            "include_raw_content": False,
            "include_images": False,
            "include_image_descriptions": False,
        }
    if tool == "resolve-library-id":
        return {"query": text, "libraryName": text}
    input_field = command_spec.get("input")
    if input_field:
        return {str(input_field): text}
    return {"input": text} if text else {}

def tokenize(value):
    out = []
    current = []
    for ch in str(value).lower():
        if ch.isalnum():
            current.append(ch)
        elif current:
            out.append("".join(current))
            current = []
    if current:
        out.append("".join(current))
    return [item for item in out if item]

def choose_tool(tools):
    if tool_name:
        return str(tool_name)
    if not tools:
        raise SystemExit(f"MCP server {server_name!r} exposes no tools")
    if len(tools) == 1:
        name = tools[0].get("name") if isinstance(tools[0], dict) else None
        if name:
            return str(name)
    desired = " ".join([
        command_name,
        str(command_spec.get("description", "")),
        user_input,
    ])
    desired_tokens = set(tokenize(desired))
    scored = []
    normalized_command = "".join(tokenize(command_name))
    for tool in tools:
        if not isinstance(tool, dict) or not tool.get("name"):
            continue
        name = str(tool.get("name"))
        desc = str(tool.get("description", ""))
        normalized_name = "".join(tokenize(name))
        tool_tokens = set(tokenize(name + " " + desc))
        score = len(desired_tokens & tool_tokens)
        if normalized_name == normalized_command:
            score += 100
        if normalized_command and normalized_command in normalized_name:
            score += 20
        if normalized_name and normalized_name in normalized_command:
            score += 10
        scored.append((score, name, desc))
    scored.sort(reverse=True, key=lambda item: item[0])
    if scored and scored[0][0] > 0 and (len(scored) == 1 or scored[0][0] > scored[1][0]):
        return scored[0][1]
    lines = [
        f"Cannot automatically choose a tool for MCP command {command_name!r} on server {server_name!r}.",
        "Available tools:",
    ]
    for _, name, desc in scored:
        lines.append(f"- {name}: {desc}" if desc else f"- {name}")
    lines.append("Add an optional tool field to this command if needed.")
    raise SystemExit("\n".join(lines))

def build_tool_arguments(selected_tool):
    if "arguments" in command_spec:
        args = render(command_spec.get("arguments", {}))
        if not isinstance(args, dict):
            raise SystemExit(f"MCP command {command_name!r} arguments must be an object")
    else:
        args = default_arguments(selected_tool, user_input)
        extra = command_spec.get("options", {}) or {}
        if not isinstance(extra, dict):
            raise SystemExit(f"MCP command {command_name!r} options must be an object")
        args.update(render(extra))
    return args

env = os.environ.copy()
for key, value in server_env.items():
    if value is not None and str(value) != "":
        env[str(key)] = str(value)

proc = subprocess.Popen(
    [str(server_command), *map(str, server_args)],
    stdin=subprocess.PIPE,
    stdout=subprocess.PIPE,
    stderr=subprocess.PIPE,
    text=True,
    bufsize=1,
    env=env,
)

stderr_lines = []
def read_stderr():
    assert proc.stderr is not None
    for line in proc.stderr:
        stderr_lines.append(line)
threading.Thread(target=read_stderr, daemon=True).start()

next_id = 1

def send(method, params=None, is_notification=False):
    global next_id
    msg = {"jsonrpc": "2.0", "method": method}
    if params is not None:
        msg["params"] = params
    if not is_notification:
        msg["id"] = next_id
        next_id += 1
    assert proc.stdin is not None
    proc.stdin.write(json.dumps(msg, separators=(",", ":")) + "\n")
    proc.stdin.flush()
    return msg.get("id")

def read_response(expected_id, timeout=60):
    assert proc.stdout is not None
    deadline = time.time() + timeout
    while time.time() < deadline:
        line = proc.stdout.readline()
        if not line:
            if proc.poll() is not None:
                err = "".join(stderr_lines).strip()
                raise SystemExit(err or f"MCP server exited with code {proc.returncode}")
            continue
        line = line.strip()
        if not line:
            continue
        try:
            msg = json.loads(line)
        except json.JSONDecodeError:
            continue
        if msg.get("id") == expected_id:
            if "error" in msg:
                raise SystemExit(json.dumps(msg["error"], ensure_ascii=False))
            return msg.get("result", {})
    raise SystemExit("timed out waiting for MCP response")

init_id = send("initialize", {
    "protocolVersion": "2024-11-05",
    "capabilities": {},
    "clientInfo": {"name": "aicmd-mcp", "version": "0.1.0"},
})
read_response(init_id)
send("notifications/initialized", {}, is_notification=True)

if tool_name:
    selected_tool_name = str(tool_name)
else:
    list_id = send("tools/list")
    list_result = read_response(list_id, timeout=60)
    selected_tool_name = choose_tool(list_result.get("tools", []))
tool_arguments = build_tool_arguments(selected_tool_name)

call_id = send("tools/call", {"name": selected_tool_name, "arguments": tool_arguments})
result = read_response(call_id, timeout=120)
content = result.get("content", [])
texts = []
for item in content:
    if isinstance(item, dict) and isinstance(item.get("text"), str):
        texts.append(item["text"])
print("\n".join(texts), end="")

try:
    proc.terminate()
except Exception:
    pass
PY
}

cmd="${1:-help}"
case "$cmd" in
  help|-h|--help)
    usage ;;
  list)
    run_mcp_command list ;;
  *)
    shift || true
    run_mcp_command "$cmd" "$@" ;;
esac
