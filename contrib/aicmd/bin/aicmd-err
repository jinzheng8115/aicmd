#!/usr/bin/env bash
set -euo pipefail

if [[ $# -eq 0 || "$1" == "-h" || "$1" == "--help" ]]; then
  cat <<HELP
Usage:
  aicmd-err -- <command> [args...]
  aicmd-err <command> [args...]

Run a command, capture stdout/stderr/exit code, then ask AICmd to generate diagnostic or fix commands.
HELP
  exit 0
fi

if [[ "$1" == "--" ]]; then
  shift
fi

if [[ $# -eq 0 ]]; then
  echo "aicmd-err: missing command" >&2
  exit 2
fi

tmp_out="$(mktemp)"
tmp_err="$(mktemp)"
cleanup() { rm -f "$tmp_out" "$tmp_err"; }
trap cleanup EXIT

set +e
"$@" >"$tmp_out" 2>"$tmp_err"
status=$?
set -e

report="$({
  printf '下面这条命令执行失败或需要检查。请生成安全的 zsh 诊断/修复命令，不要直接删除数据。\n'
  printf 'Command: '
  printf '%q ' "$@"
  printf '\nExit code: %s\n\n' "$status"
  printf 'STDOUT:\n'
  cat "$tmp_out"
  printf '\n\nSTDERR:\n'
  cat "$tmp_err"
  printf '\n'
})"

aicmd "$report"
exit 0
