#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<HELP
Usage: aicmd-do [--dry-run] [--output PATH] <task>

Ask AICmd to generate shell commands that create a script for a local file/data task, then run it after AICmd's normal confirmation flow.

用法：aicmd-do [--dry-run] [--output PATH] <任务>

让 AICmd 生成 shell 命令：创建一个本地脚本处理文件/数据任务，并通过 AICmd 正常确认流程执行。

Examples:
  aicmd-do "统计 data.csv 每列的空值数量"
  aicmd-do --output scripts/clean-data.sh "清洗 input.csv，输出 cleaned.csv"
  aicmd-do --dry-run "处理 logs/*.log，提取 ERROR 行到 errors.txt"
HELP
}

dry_run=false
output=""
task_parts=()

while [[ $# -gt 0 ]]; do
  case "$1" in
    --dry-run)
      dry_run=true; shift ;;
    -o|--output)
      output="$2"; shift 2 ;;
    --output=*)
      output="${1#--output=}"; shift ;;
    -h|--help)
      usage; exit 0 ;;
    --*)
      echo "Unknown option: $1" >&2; exit 2 ;;
    *)
      task_parts+=("$1"); shift ;;
  esac
done

if [[ ${#task_parts[@]} -eq 0 ]]; then
  usage >&2
  exit 2
fi

task="${task_parts[*]}"
if [[ -n "$output" ]]; then
  script_path="$output"
else
  script_path=".aicmd/task-$(date +%Y%m%d-%H%M%S).sh"
fi

prompt="创建一个 zsh 脚本 ${script_path} 来完成这个任务: ${task}。要求：先检查输入文件是否存在；必要时创建输出目录；不要删除或覆盖原始文件，除非任务明确要求；脚本写入后 chmod +x；最后执行这个脚本。"

args=()
if [[ "$dry_run" == "true" ]]; then
  args+=(--dry-run)
fi

exec aicmd "${args[@]}" "$prompt"
