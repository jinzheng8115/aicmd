#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'HELP'
Usage: aicmd-model <command>

Manage the AICmd runtime model config at ~/.aicmd/config.yaml and MCP config at ~/.aicmd/config.json.
The recommended setup is: copy .env.example to .env, fill the model and MCP values, then run `aicmd-model init --from-env`.

用法：aicmd-model <命令>

管理 AICmd 运行时模型配置 ~/.aicmd/config.yaml 和 MCP 配置 ~/.aicmd/config.json。
推荐流程：复制 .env.example 为 .env，填写模型和 MCP 参数，然后运行 `aicmd-model init --from-env`。

Commands / 命令:
  init                Create runtime config.yaml and config.json. Uses .env when found, otherwise writes starter configs.
                      创建运行时 config.yaml 和 config.json。发现 .env 时读取它，否则写入初始配置。
  init --from-env     Require .env and generate config.yaml/config.json from it / 必须读取 .env 并生成配置
  init --force        Overwrite runtime config.yaml/config.json / 覆盖运行时配置
  path                Print runtime config.yaml path / 输出运行时 config.yaml 路径
  dir                 Print runtime config directory / 输出运行时配置目录
  show                Print runtime config.yaml / 输出运行时配置
  edit                Open runtime config.yaml in $EDITOR / 用 $EDITOR 编辑运行时配置
  help                Show this help / 显示帮助

Examples / 示例:
  cp .env.example .env
  $EDITOR .env
  aicmd-model init --from-env
  aicmd-model show
HELP
}

config_dir() {
  if [[ -n "${AICMD_CONFIG_DIR:-}" ]]; then
    printf '%s\n' "$AICMD_CONFIG_DIR"
  else
    printf '%s/.aicmd\n' "$HOME"
  fi
}

config_path() {
  if [[ -n "${AICMD_CONFIG_FILE:-}" ]]; then
    printf '%s\n' "$AICMD_CONFIG_FILE"
  else
    printf '%s/config.yaml\n' "$(config_dir)"
  fi
}


mcp_config_path() {
  if [[ -n "${AICMD_MCP_CONFIG_FILE:-}" ]]; then
    printf '%s\n' "$AICMD_MCP_CONFIG_FILE"
  else
    printf '%s/config.json\n' "$(config_dir)"
  fi
}

find_env_file() {
  if [[ -n "${AICMD_MODEL_ENV:-}" ]]; then
    printf '%s\n' "$AICMD_MODEL_ENV"
  elif [[ -f .env ]]; then
    printf '%s\n' ".env"
  else
    local script_dir root
    script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
    root="$(cd "$script_dir/../../.." && pwd)"
    if [[ -f "$root/.env" ]]; then
      printf '%s\n' "$root/.env"
    fi
  fi
}

load_model_env() {
  local env_file="$1"
  set -a
  # shellcheck disable=SC1090
  source "$env_file"
  set +a
}

required_env() {
  local name="$1"
  local value="${!name:-}"
  if [[ -z "$value" ]]; then
    echo "missing required env: $name" >&2
    exit 1
  fi
  printf '%s\n' "$value"
}

yaml_escape() {
  local value
  value="$(cat)"
  value="${value//\\/\\\\}"
  value="${value//"/\\"}"
  printf '"%s"\n' "$value"
}

json_escape() {
  python3 -c 'import json,sys; print(json.dumps(sys.stdin.read()))'
}

config_from_env() {
  local provider name api_base api_key model_ids first_model_id default_model openai_api_style client_type
  provider="$(required_env AICMD_MODEL_PROVIDER)"
  name="$(required_env AICMD_MODEL_NAME)"
  api_base="$(required_env AICMD_MODEL_API_BASE)"
  api_key="$(required_env AICMD_MODEL_API_KEY)"
  model_ids="$(required_env AICMD_MODEL_IDS)"
  first_model_id="${model_ids%%,*}"
  first_model_id="$(printf '%s' "$first_model_id" | xargs)"
  default_model="${AICMD_DEFAULT_MODEL:-${name}:${first_model_id}}"
  if [[ "$default_model" != *:* ]]; then
    default_model="${name}:${default_model}"
  fi
  openai_api_style="${AICMD_OPENAI_API_STYLE:-chat}"

  case "$provider" in
    openai)
      client_type="openai"
      if [[ "$openai_api_style" != "chat" && "$openai_api_style" != "responses" ]]; then
        echo "AICMD_OPENAI_API_STYLE must be chat or responses" >&2
        exit 1
      fi
      ;;
    anthropic)
      client_type="claude" ;;
    google)
      client_type="gemini" ;;
    *)
      echo "AICMD_MODEL_PROVIDER must be openai, anthropic, or google" >&2
      exit 1 ;;
  esac

  cat <<YAML
# AICmd runtime config / AICmd 运行时配置
# Generated from .env. Edit this file directly after installation.
# 由 .env 生成。安装后如需调整，请直接编辑本文件。

model: ${default_model}

temperature: null
top_p: null
stream: false
save: true
wrap: no
highlight: true
save_shell_history: true

document_loaders:
  pdf: 'pdftotext \$1 -'
  docx: 'pandoc --to plain \$1'

clients:
  - type: ${client_type}
    name: $(printf '%s' "$name" | yaml_escape)
    api_base: $(printf '%s' "$api_base" | yaml_escape)
    api_key: $(printf '%s' "$api_key" | yaml_escape)
YAML

  if [[ "$provider" == "openai" ]]; then
    cat <<YAML
    api_style: ${openai_api_style}
YAML
  fi

  cat <<YAML
    models:
YAML

  local old_ifs model_id
  old_ifs="$IFS"
  IFS=','
  for model_id in $model_ids; do
    IFS="$old_ifs"
    model_id="$(printf '%s' "$model_id" | xargs)"
    if [[ -n "$model_id" ]]; then
      printf '      - name: %s\n' "$(printf '%s' "$model_id" | yaml_escape)"
    fi
    IFS=','
  done
  IFS="$old_ifs"
}

mcp_config_from_env() {
  local tavily_key tavily_keys_file tavily_script
  tavily_key="${AICMD_MCP_TAVILY_API_KEY:-}"
  tavily_keys_file="${AICMD_MCP_TAVILY_API_KEYS_FILE:-}"
  tavily_script="${AICMD_MCP_TAVILY_SCRIPT:-$HOME/Library/Application Support/aichat/functions/tools/tavily_mcp_search.mjs}"
  cat <<JSON
{
  "mcp": {
    "tavily": {
      "api_key": $(printf '%s' "$tavily_key" | json_escape),
      "api_keys_file": $(printf '%s' "$tavily_keys_file" | json_escape),
      "script": $(printf '%s' "$tavily_script" | json_escape)
    }
  }
}
JSON
}

default_mcp_config() {
  cat <<JSON
{
  "mcp": {
    "tavily": {
      "api_key": "",
      "api_keys_file": "",
      "script": "$HOME/Library/Application Support/aichat/functions/tools/tavily_mcp_search.mjs"
    }
  }
}
JSON
}

default_config() {
  cat <<'YAML'
# AICmd runtime config / AICmd 运行时配置
#
# Recommended: copy .env.example to .env, fill model values, then run:
#   aicmd-model init --from-env
#
# 推荐：复制 .env.example 为 .env，填写模型参数，然后运行：
#   aicmd-model init --from-env

model: openai:gpt-4o

temperature: null
top_p: null
stream: false
save: true
wrap: no
highlight: true
save_shell_history: true

document_loaders:
  pdf: 'pdftotext $1 -'
  docx: 'pandoc --to plain $1'

clients:
  - type: openai
    name: openai
    api_base: https://api.openai.com/v1
    api_key: sk-xxxx
    api_style: chat
    models:
      - name: gpt-4o
YAML
}

confirm_init() {
  local path="$1" source_desc="$2"
  echo "About to write AICmd config: $path" >&2
  echo "Source: $source_desc" >&2
  printf 'Continue? [y/N] ' >&2
  local answer
  read -r answer
  case "$answer" in
    y|Y|yes|YES) ;;
    *) echo "cancelled" >&2; exit 1 ;;
  esac
}

init_config() {
  local force="$1" from_env="$2" path mcp_path env_file
  path="$(config_path)"
  mcp_path="$(mcp_config_path)"
  if [[ "$force" != "true" ]]; then
    if [[ -f "$path" ]]; then
      echo "config already exists: $path" >&2
      echo "use 'aicmd-model init --force' to overwrite it" >&2
      exit 1
    fi
    if [[ -f "$mcp_path" ]]; then
      echo "MCP config already exists: $mcp_path" >&2
      echo "use 'aicmd-model init --force' to overwrite it" >&2
      exit 1
    fi
  fi

  env_file="$(find_env_file || true)"
  if [[ -n "$env_file" ]]; then
    confirm_init "$path and $mcp_path" "$env_file"
    mkdir -p "$(dirname "$path")" "$(dirname "$mcp_path")"
    load_model_env "$env_file"
    config_from_env > "$path"
    mcp_config_from_env > "$mcp_path"
    echo "created config from env: $path"
    echo "created MCP config from env: $mcp_path"
    echo "env file: $env_file"
  elif [[ "$from_env" == "true" ]]; then
    echo "env file not found. Copy .env.example to .env and fill it first." >&2
    exit 1
  else
    confirm_init "$path and $mcp_path" "built-in starter config"
    mkdir -p "$(dirname "$path")" "$(dirname "$mcp_path")"
    default_config > "$path"
    default_mcp_config > "$mcp_path"
    echo "created starter config: $path"
    echo "created starter MCP config: $mcp_path"
  fi
  chmod 600 "$path" "$mcp_path" 2>/dev/null || true
  echo "edit model config with: aicmd-model edit"
  echo "edit MCP config with: ${EDITOR:-vi} $mcp_path"
}

cmd="${1:-help}"
case "$cmd" in
  init)
    force=false
    from_env=false
    shift || true
    for arg in "$@"; do
      case "$arg" in
        --force) force=true ;;
        --from-env) from_env=true ;;
        *) echo "Unknown option for init: $arg" >&2; exit 2 ;;
      esac
    done
    init_config "$force" "$from_env" ;;
  path)
    config_path ;;
  dir)
    config_dir ;;
  show)
    path="$(config_path)"
    if [[ ! -f "$path" ]]; then
      echo "config not found: $path" >&2
      echo "run 'aicmd-model init --from-env' to create it" >&2
      exit 1
    fi
    cat "$path" ;;
  edit)
    path="$(config_path)"
    if [[ ! -f "$path" ]]; then
      init_config false false >/dev/null
    fi
    editor="${EDITOR:-vi}"
    exec "$editor" "$path" ;;
  help|-h|--help)
    usage ;;
  *)
    echo "Unknown command: $cmd" >&2
    usage >&2
    exit 2 ;;
esac
