#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'HELP'
Usage: aicmd-model <command>

Manage AICmd model configuration. AICmd does not sync models.yaml into config.yaml.
Customers should initialize and edit the runtime config.yaml, using model-config.example.yaml as the template.

用法：aicmd-model <命令>

管理 AICmd 模型配置。AICmd 不会把 models.yaml 同步到 config.yaml。
客户应初始化并编辑运行时 config.yaml，并以 model-config.example.yaml 作为模板。

Commands / 命令:
  init       Create runtime config.yaml from model-config.example.yaml if missing / 如不存在则从模板创建运行时配置
  init --force
             Overwrite runtime config.yaml from template / 用模板覆盖运行时配置
  path       Print runtime config.yaml path / 输出运行时 config.yaml 路径
  dir        Print runtime config directory / 输出运行时配置目录
  template   Print model-config.example.yaml path / 输出模型配置模板路径
  show       Print runtime config.yaml / 输出运行时配置
  edit       Open runtime config.yaml in $EDITOR / 用 $EDITOR 编辑运行时配置
  help       Show this help / 显示帮助

Examples / 示例:
  aicmd-model init
  aicmd-model path
  aicmd-model show
  EDITOR=vim aicmd-model edit
HELP
}

config_dir() {
  if [[ -n "${AICMD_CONFIG_DIR:-}" ]]; then
    printf '%s\n' "$AICMD_CONFIG_DIR"
  else
    printf '%s/.aicmd\n' "$HOME"
  fi
}

config_path() {
  if [[ -n "${AICMD_CONFIG_FILE:-}" ]]; then
    printf '%s\n' "$AICMD_CONFIG_FILE"
  else
    printf '%s/config.yaml\n' "$(config_dir)"
  fi
}

template_path() {
  local script_dir root
  script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
  root="$(cd "$script_dir/../../.." && pwd)"
  if [[ -f "$root/model-config.example.yaml" ]]; then
    printf '%s/model-config.example.yaml\n' "$root"
  else
    printf 'model-config.example.yaml\n'
  fi
}

init_config() {
  local force path template
  force="${1:-false}"
  path="$(config_path)"
  template="$(template_path)"
  if [[ ! -f "$template" ]]; then
    echo "template not found: $template" >&2
    exit 1
  fi
  if [[ -f "$path" && "$force" != "true" ]]; then
    echo "config already exists: $path" >&2
    echo "use 'aicmd-model init --force' to overwrite it" >&2
    exit 1
  fi
  mkdir -p "$(dirname "$path")"
  cp "$template" "$path"
  chmod 600 "$path" 2>/dev/null || true
  echo "created config: $path"
  echo "edit it with: aicmd-model edit"
}

cmd="${1:-help}"
case "$cmd" in
  init)
    force=false
    if [[ "${2:-}" == "--force" ]]; then
      force=true
    elif [[ -n "${2:-}" ]]; then
      echo "Unknown option for init: $2" >&2
      exit 2
    fi
    init_config "$force" ;;
  path)
    config_path ;;
  dir)
    config_dir ;;
  template)
    template_path ;;
  show)
    path="$(config_path)"
    if [[ ! -f "$path" ]]; then
      echo "config not found: $path" >&2
      echo "run 'aicmd-model init' to create it from: $(template_path)" >&2
      exit 1
    fi
    cat "$path" ;;
  edit)
    path="$(config_path)"
    if [[ ! -f "$path" ]]; then
      init_config false >/dev/null
    fi
    editor="${EDITOR:-vi}"
    exec "$editor" "$path" ;;
  help|-h|--help)
    usage ;;
  *)
    echo "Unknown command: $cmd" >&2
    usage >&2
    exit 2 ;;
esac
