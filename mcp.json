{
  "mcp": {
    "servers": {
      "tavily": {
        "type": "stdio",
        "command": "npx",
        "args": [
          "-y",
          "tavily-mcp"
        ],
        "env": {
          "TAVILY_API_KEY": "tvly-xxxx",
          "TAVILY_API_KEYS_FILE": ""
        }
      },
      "context7": {
        "type": "stdio",
        "command": "npx",
        "args": [
          "-y",
          "@upstash/context7-mcp"
        ]
      }
    },
    "commands": {
      "search": {
        "description": "Search the web using Tavily",
        "server": "tavily",
        "tool": "tavily_search",
        "arguments": {
          "query": "{{input}}",
          "topic": "general",
          "search_depth": "advanced",
          "max_results": 5,
          "include_answer": true,
          "include_raw_content": false,
          "include_images": false,
          "include_image_descriptions": false
        }
      },
      "context7-library": {
        "description": "Resolve a package/library name using Context7",
        "server": "context7",
        "tool": "resolve-library-id",
        "arguments": {
          "libraryName": "{{input}}"
        }
      },
      "tavily": {
        "description": "Alias of search using Tavily",
        "server": "tavily",
        "tool": "tavily_search",
        "arguments": {
          "query": "{{input}}",
          "topic": "general",
          "search_depth": "advanced",
          "max_results": 5,
          "include_answer": true,
          "include_raw_content": false,
          "include_images": false,
          "include_image_descriptions": false
        }
      }
    }
  }
}
